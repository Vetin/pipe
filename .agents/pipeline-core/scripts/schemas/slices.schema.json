{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Native Feature Pipeline slices",
  "type": "object",
  "required": ["artifact_contract_version", "feature_key", "slices"],
  "properties": {
    "artifact_contract_version": { "const": "0.1.0" },
    "feature_key": { "type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$" },
    "slices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "linked_requirements",
          "linked_acceptance_criteria",
          "expected_touchpoints",
          "scope_confidence",
          "tdd",
          "verification_commands",
          "review_focus",
          "status"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^S-[0-9]{3}$" },
          "title": { "type": "string", "minLength": 1 },
          "linked_requirements": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "linked_acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "linked_adrs": { "type": "array", "items": { "type": "string" } },
          "linked_contracts": { "type": "array", "items": { "type": "string" } },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "priority": { "type": ["integer", "string"] },
          "expected_touchpoints": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "scope_confidence": { "enum": ["low", "medium", "high"] },
          "tdd": {
            "type": "object",
            "required": ["failing_test_file", "red_command", "expected_failure", "green_command"],
            "properties": {
              "failing_test_file": { "type": "string", "minLength": 1 },
              "red_command": { "type": "string", "minLength": 1 },
              "expected_failure": { "type": "string", "minLength": 1 },
              "green_command": { "type": "string", "minLength": 1 }
            }
          },
          "verification_commands": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "review_focus": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "evidence_status": { "type": "string" },
          "status": { "type": "string" }
        },
        "not": {
          "anyOf": [
            { "required": ["allowed_files"] },
            { "required": ["forbidden_files"] }
          ]
        }
      }
    }
  }
}
