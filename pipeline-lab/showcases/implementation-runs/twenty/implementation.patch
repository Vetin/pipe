--- /dev/null
+++ b/showcase/duplicate-company-merge-audit-trail/feature.s-002.test.js
@@ -0,0 +1,19 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow } = require('./feature');
+
+const model = createModel({ id: "duplicate-company-merge-audit-trail-002" });
+const reviewed = executeWorkflow(
+  model,
+  "preview_merge",
+  { id: 'reviewer-1' },
+  { reason: "duplicate company merge with audit trail" }
+);
+assert.equal(reviewed.state, "previewed");
+assert.equal(reviewed.history.at(-1).previousState, "duplicates_detected");
+assert.equal(reviewed.history.at(-1).actor, 'reviewer-1');
+
+const finalized = executeWorkflow(reviewed, "merge_company", { id: 'approver-1' });
+assert.equal(finalized.state, "merged");
+assert.equal(finalized.history.length, 3);
diff --git a/showcase/duplicate-company-merge-audit-trail/feature.s-003.test.js b/showcase/duplicate-company-merge-audit-trail/feature.s-003.test.js
