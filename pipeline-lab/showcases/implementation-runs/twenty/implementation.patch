+'use strict';
+
+const assert = require('assert/strict');
+const { FEATURE, createModel } = require('./feature');
+
+const model = createModel({ id: "duplicate-company-merge-audit-trail-001", entity: { title: "Duplicate Company Merge Audit Trail" } });
+assert.equal(FEATURE.key, "duplicate-company-merge-audit-trail");
+assert.equal(model.state, "duplicates_detected");
+assert.equal(model.history[0].type, 'created');
+assert.equal(model.entity.title, "Duplicate Company Merge Audit Trail");
diff --git a/showcase/duplicate-company-merge-audit-trail/feature.s-002.test.js b/showcase/duplicate-company-merge-audit-trail/feature.s-002.test.js
