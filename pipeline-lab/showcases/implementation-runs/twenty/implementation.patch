index 0000000..1057ec7
--- /dev/null
+++ b/showcase/duplicate-company-merge-audit-trail/feature.s-003.test.js
@@ -0,0 +1,14 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow, inspectHistory } = require('./feature');
+
+let model = createModel({ id: "duplicate-company-merge-audit-trail-003" });
+model = executeWorkflow(model, "preview_merge", { id: 'actor-1' });
+model = executeWorkflow(model, "merge_company", { id: 'actor-2' }, { evidence: true });
+const audit = inspectHistory(model);
+
+assert.equal(audit.auditLabel, "merge audit trail");
+assert.equal(audit.latestState, "merged");
+assert.equal(audit.transitions.length, 2);
+assert.match(audit.rollbackHint, /reconstruct/i);
