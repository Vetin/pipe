+++ b/showcase/double-opt-in-segment-onboarding/feature_s_003_test.go
@@ -0,0 +1,22 @@
+package doubleoptinsegmentonboarding
+
+import "testing"
+
+func TestInspectHistory(t *testing.T) {
+	model := CreateModel("double-opt-in-segment-onboarding-003")
+	model, _ = ExecuteWorkflow(model, "import_pending_subscriber", "actor-1")
+	model, _ = ExecuteWorkflow(model, "confirm_subscription", "actor-2")
+	audit := InspectHistory(model)
+	if audit.AuditLabel != "consent audit" {
+		t.Fatalf("audit label = %s", audit.AuditLabel)
+	}
+	if audit.LatestState != "active" {
+		t.Fatalf("latest state = %s", audit.LatestState)
+	}
+	if len(audit.Transitions) != 2 {
+		t.Fatalf("transitions = %d", len(audit.Transitions))
+	}
+	if audit.RollbackHint == "" {
+		t.Fatalf("expected rollback hint")
+	}
+}
