+package doubleoptinsegmentonboarding
+
+import "errors"
+
+var (
+	ErrMissingActor      = errors.New("actor id is required for auditable workflow execution")
+	ErrUnsupportedAction = errors.New("unsupported action")
+)
diff --git a/showcase/double-opt-in-segment-onboarding/feature.go b/showcase/double-opt-in-segment-onboarding/feature.go
new file mode 100644
index 0000000..8d8e956
--- /dev/null
+++ b/showcase/double-opt-in-segment-onboarding/feature.go
@@ -0,0 +1,85 @@
+package doubleoptinsegmentonboarding
+
+type Event struct {
+	Type          string
+	Action        string
+	PreviousState string
+	NextState     string
+	Actor         string
+	Note          string
+}
+
+type Model struct {
+	ID          string
+	FeatureKey  string
+	Scenario    string
+	State       string
+	History     []Event
+}
+
+func CreateModel(id string) Model {
+	if id == "" {
+		id = "double-opt-in-segment-onboarding-entity"
+	}
+	return Model{
+		ID:         id,
+		FeatureKey: "double-opt-in-segment-onboarding",
+		Scenario:   "double opt-in segment onboarding",
+		State:      "imported",
+		History: []Event{{
+			Type: "created",
+			Note: "Double Opt In Segment Onboarding",
+		}},
+	}
+}
+
+
+func ExecuteWorkflow(model Model, action string, actor string) (Model, error) {
+	if actor == "" {
+		return model, ErrMissingActor
+	}
+	nextState, ok := map[string]string{
+		"import_pending_subscriber": "pending_confirmation",
+		"confirm_subscription": "active",
+	}[action]
+	if !ok {
+		return model, ErrUnsupportedAction
+	}
+	event := Event{
+		Type: "transition",
+		Action: action,
+		PreviousState: model.State,
+		NextState: nextState,
+		Actor: actor,
+	}
+	model.State = nextState
+	model.History = append(model.History, event)
+	return model, nil
+}
+
+
+type Audit struct {
+	FeatureKey   string
+	AuditLabel   string
+	LatestState  string
+	EventCount   int
+	Transitions  []Event
+	RollbackHint string
+}
+
+func InspectHistory(model Model) Audit {
+	transitions := make([]Event, 0)
+	for _, event := range model.History {
+		if event.Type == "transition" {
+			transitions = append(transitions, event)
+		}
+	}
+	return Audit{
+		FeatureKey: "double-opt-in-segment-onboarding",
+		AuditLabel: "consent audit",
+		LatestState: model.State,
+		EventCount: len(model.History),
+		Transitions: transitions,
+		RollbackHint: "expire confirmation token and keep subscriber outside active segment",
+	}
+}
diff --git a/showcase/double-opt-in-segment-onboarding/feature_s_001_test.go b/showcase/double-opt-in-segment-onboarding/feature_s_001_test.go
