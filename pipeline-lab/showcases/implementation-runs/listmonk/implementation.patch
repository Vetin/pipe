@@ -0,0 +1,24 @@
+package doubleoptinsegmentonboarding
+
+import "testing"
+
+func TestExecuteWorkflow(t *testing.T) {
+	model := CreateModel("double-opt-in-segment-onboarding-002")
+	model, err := ExecuteWorkflow(model, "import_pending_subscriber", "reviewer-1")
+	if err != nil {
+		t.Fatal(err)
+	}
+	if model.State != "pending_confirmation" {
+		t.Fatalf("state = %s", model.State)
+	}
+	model, err = ExecuteWorkflow(model, "confirm_subscription", "approver-1")
+	if err != nil {
+		t.Fatal(err)
+	}
+	if model.State != "active" {
+		t.Fatalf("state = %s", model.State)
+	}
+	if len(model.History) != 3 {
+		t.Fatalf("history len = %d", len(model.History))
+	}
+}
diff --git a/showcase/double-opt-in-segment-onboarding/feature_s_003_test.go b/showcase/double-opt-in-segment-onboarding/feature_s_003_test.go
