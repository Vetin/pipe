+++ b/showcase/double-opt-in-segment-onboarding/feature_s_001_test.go
@@ -0,0 +1,16 @@
+package doubleoptinsegmentonboarding
+
+import "testing"
+
+func TestCreateModel(t *testing.T) {
+	model := CreateModel("double-opt-in-segment-onboarding-001")
+	if model.FeatureKey != "double-opt-in-segment-onboarding" {
+		t.Fatalf("feature key = %s", model.FeatureKey)
+	}
+	if model.State != "imported" {
+		t.Fatalf("state = %s", model.State)
+	}
+	if len(model.History) != 1 || model.History[0].Type != "created" {
+		t.Fatalf("expected created history event")
+	}
+}
diff --git a/showcase/double-opt-in-segment-onboarding/feature_s_002_test.go b/showcase/double-opt-in-segment-onboarding/feature_s_002_test.go
