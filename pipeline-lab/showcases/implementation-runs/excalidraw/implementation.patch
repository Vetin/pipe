--- /dev/null
+++ b/showcase/layer-lock-history-safe-editing/feature.s-003.test.js
@@ -0,0 +1,14 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow, inspectHistory } = require('./feature');
+
+let model = createModel({ id: 'layer-lock-history-safe-editing-003' });
+model = executeWorkflow(model, 'lock_layer', { id: 'actor-1' });
+model = executeWorkflow(model, 'reject_locked_edit', { id: 'actor-2' }, { evidence: true });
+const audit = inspectHistory(model);
+
+assert.equal(audit.auditLabel, 'history-safe lock event');
+assert.equal(audit.latestState, 'edit_rejected');
+assert.equal(audit.transitions.length, 2);
+assert.match(audit.rollbackHint, /undo/i);
