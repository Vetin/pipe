+'use strict';
+
+const assert = require('assert/strict');
+const { FEATURE, createModel } = require('./feature');
+
+const model = createModel({ id: 'layer-lock-history-safe-editing-001', entity: { title: 'Layer Lock History Safe Editing' } });
+assert.equal(FEATURE.key, 'layer-lock-history-safe-editing');
+assert.equal(model.state, 'editable');
+assert.equal(model.history[0].type, 'created');
+assert.equal(model.entity.title, 'Layer Lock History Safe Editing');
diff --git a/showcase/layer-lock-history-safe-editing/feature.s-002.test.js b/showcase/layer-lock-history-safe-editing/feature.s-002.test.js
new file mode 100644
index 0000000..3217517
--- /dev/null
+++ b/showcase/layer-lock-history-safe-editing/feature.s-002.test.js
@@ -0,0 +1,19 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow } = require('./feature');
+
+const model = createModel({ id: 'layer-lock-history-safe-editing-002' });
+const reviewed = executeWorkflow(
+  model,
+  'lock_layer',
+  { id: 'reviewer-1' },
+  { reason: 'layer lock and history-safe editing' }
+);
+assert.equal(reviewed.state, 'locked');
+assert.equal(reviewed.history.at(-1).previousState, 'editable');
+assert.equal(reviewed.history.at(-1).actor, 'reviewer-1');
+
+const finalized = executeWorkflow(reviewed, 'reject_locked_edit', { id: 'approver-1' });
+assert.equal(finalized.state, 'edit_rejected');
+assert.equal(finalized.history.length, 3);
diff --git a/showcase/layer-lock-history-safe-editing/feature.s-003.test.js b/showcase/layer-lock-history-safe-editing/feature.s-003.test.js
