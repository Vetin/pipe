+'use strict';
+
+const assert = require('assert/strict');
+const { FEATURE, createModel } = require('./feature');
+
+const model = createModel({ id: 'app-version-restore-diff-preview-001', entity: { title: 'App Version Restore Diff Preview' } });
+assert.equal(FEATURE.key, 'app-version-restore-diff-preview');
+assert.equal(model.state, 'current');
+assert.equal(model.history[0].type, 'created');
+assert.equal(model.entity.title, 'App Version Restore Diff Preview');
diff --git a/showcase/app-version-restore-diff-preview/feature.s-002.test.js b/showcase/app-version-restore-diff-preview/feature.s-002.test.js
