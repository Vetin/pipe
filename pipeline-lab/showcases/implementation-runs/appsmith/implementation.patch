--- /dev/null
+++ b/showcase/app-version-restore-diff-preview/feature.s-002.test.js
@@ -0,0 +1,19 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow } = require('./feature');
+
+const model = createModel({ id: 'app-version-restore-diff-preview-002' });
+const reviewed = executeWorkflow(
+  model,
+  'preview_diff',
+  { id: 'reviewer-1' },
+  { reason: 'app version restore with diff preview' }
+);
+assert.equal(reviewed.state, 'diffed');
+assert.equal(reviewed.history.at(-1).previousState, 'current');
+assert.equal(reviewed.history.at(-1).actor, 'reviewer-1');
+
+const finalized = executeWorkflow(reviewed, 'restore_version', { id: 'approver-1' });
+assert.equal(finalized.state, 'restored');
+assert.equal(finalized.history.length, 3);
diff --git a/showcase/app-version-restore-diff-preview/feature.s-003.test.js b/showcase/app-version-restore-diff-preview/feature.s-003.test.js
