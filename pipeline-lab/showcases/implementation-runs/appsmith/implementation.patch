--- /dev/null
+++ b/showcase/app-version-restore-diff-preview/feature.s-003.test.js
@@ -0,0 +1,14 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow, inspectHistory } = require('./feature');
+
+let model = createModel({ id: 'app-version-restore-diff-preview-003' });
+model = executeWorkflow(model, 'preview_diff', { id: 'actor-1' });
+model = executeWorkflow(model, 'restore_version', { id: 'actor-2' }, { evidence: true });
+const audit = inspectHistory(model);
+
+assert.equal(audit.auditLabel, 'restore audit');
+assert.equal(audit.latestState, 'restored');
+assert.equal(audit.transitions.length, 2);
+assert.match(audit.rollbackHint, /restore/i);
