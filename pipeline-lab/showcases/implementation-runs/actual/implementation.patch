diff --git a/showcase/rule-preview-and-undo/feature.js b/showcase/rule-preview-and-undo/feature.js
new file mode 100644
index 0000000..3d854f7
--- /dev/null
+++ b/showcase/rule-preview-and-undo/feature.js
@@ -0,0 +1,77 @@
+'use strict';
+
+const FEATURE = {
+  "key": "rule-preview-and-undo",
+  "name": "Rule Preview And Undo",
+  "scenario": "transaction import rule preview and undo",
+  "auditLabel": "undo ledger"
+};
+
+function clone(value) {
+  return JSON.parse(JSON.stringify(value));
+}
+
+function createModel(input = {}) {
+  const entity = clone(input.entity || input);
+  return {
+    id: input.id || entity.id || `${FEATURE.key}-entity`,
+    featureKey: FEATURE.key,
+    scenario: FEATURE.scenario,
+    state: "imported",
+    entity,
+    history: [
+      {
+        type: 'created',
+        state: "imported",
+        actor: 'system',
+        note: FEATURE.name,
+      },
+    ],
+  };
+}
+
+
+const TRANSITIONS = {
+  "preview_rules": "previewed",
+  "apply_with_undo_token": "applied",
+};
+
+function executeWorkflow(model, action, actor = {}, meta = {}) {
+  if (!TRANSITIONS[action]) {
+    throw new Error(`unsupported action: ${action}`);
+  }
+  if (!actor.id) {
+    throw new Error('actor id is required for auditable workflow execution');
+  }
+  const nextState = TRANSITIONS[action];
+  const previousState = model.state;
+  const event = {
+    type: 'transition',
+    action,
+    previousState,
+    nextState,
+    actor: actor.id,
+    meta: clone(meta),
+  };
+  return {
+    ...model,
+    state: nextState,
+    history: [...model.history, event],
+  };
+}
+
+
+function inspectHistory(model) {
+  const events = model.history.map((event, index) => ({ ...clone(event), index }));
+  const transitions = events.filter((event) => event.type === 'transition');
+  return {
+    featureKey: FEATURE.key,
+    auditLabel: "undo ledger",
+    eventCount: events.length,
+    latestState: model.state,
+    transitions,
+    rollbackHint: "apply inverse transaction patch from undo ledger",
+  };
+}
+
+module.exports = { FEATURE, createModel, executeWorkflow, inspectHistory };
diff --git a/showcase/rule-preview-and-undo/feature.s-001.test.js b/showcase/rule-preview-and-undo/feature.s-001.test.js
