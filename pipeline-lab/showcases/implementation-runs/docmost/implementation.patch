@@ -0,0 +1,10 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { FEATURE, createModel } = require('./feature');
+
+const model = createModel({ id: 'page-approval-workflow-001', entity: { title: 'Page Approval Workflow' } });
+assert.equal(FEATURE.key, 'page-approval-workflow');
+assert.equal(model.state, 'draft');
+assert.equal(model.history[0].type, 'created');
+assert.equal(model.entity.title, 'Page Approval Workflow');
diff --git a/showcase/page-approval-workflow/feature.s-002.test.js b/showcase/page-approval-workflow/feature.s-002.test.js
new file mode 100644
index 0000000..4525242
--- /dev/null
+++ b/showcase/page-approval-workflow/feature.s-002.test.js
@@ -0,0 +1,19 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow } = require('./feature');
+
+const model = createModel({ id: 'page-approval-workflow-002' });
+const reviewed = executeWorkflow(
+  model,
+  'submit_for_review',
+  { id: 'reviewer-1' },
+  { reason: 'page approval workflow' }
+);
+assert.equal(reviewed.state, 'review');
+assert.equal(reviewed.history.at(-1).previousState, 'draft');
+assert.equal(reviewed.history.at(-1).actor, 'reviewer-1');
+
+const finalized = executeWorkflow(reviewed, 'approve', { id: 'approver-1' });
+assert.equal(finalized.state, 'approved');
+assert.equal(finalized.history.length, 3);
diff --git a/showcase/page-approval-workflow/feature.s-003.test.js b/showcase/page-approval-workflow/feature.s-003.test.js
new file mode 100644
index 0000000..67082b0
--- /dev/null
+++ b/showcase/page-approval-workflow/feature.s-003.test.js
@@ -0,0 +1,14 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow, inspectHistory } = require('./feature');
+
+let model = createModel({ id: 'page-approval-workflow-003' });
+model = executeWorkflow(model, 'submit_for_review', { id: 'actor-1' });
+model = executeWorkflow(model, 'approve', { id: 'actor-2' }, { evidence: true });
+const audit = inspectHistory(model);
+
+assert.equal(audit.auditLabel, 'approval history');
+assert.equal(audit.latestState, 'approved');
+assert.equal(audit.transitions.length, 2);
+assert.match(audit.rollbackHint, /reopen/i);
