@@ -0,0 +1,77 @@
+'use strict';
+
+const FEATURE = {
+  "key": "first-order-promotion-usage-caps",
+  "name": "First Order Promotion Usage Caps",
+  "scenario": "first-order promotion with usage caps",
+  "auditLabel": "promotion usage ledger"
+};
+
+function clone(value) {
+  return JSON.parse(JSON.stringify(value));
+}
+
+function createModel(input = {}) {
+  const entity = clone(input.entity || input);
+  return {
+    id: input.id || entity.id || `${FEATURE.key}-entity`,
+    featureKey: FEATURE.key,
+    scenario: FEATURE.scenario,
+    state: 'cart',
+    entity,
+    history: [
+      {
+        type: 'created',
+        state: 'cart',
+        actor: 'system',
+        note: FEATURE.name,
+      },
+    ],
+  };
+}
+
+
+const TRANSITIONS = {
+  'evaluate_first_order': 'eligible',
+  'reserve_usage_cap': 'reserved',
+};
+
+function executeWorkflow(model, action, actor = {}, meta = {}) {
+  if (!TRANSITIONS[action]) {
+    throw new Error(`unsupported action: ${action}`);
+  }
+  if (!actor.id) {
+    throw new Error('actor id is required for auditable workflow execution');
+  }
+  const nextState = TRANSITIONS[action];
+  const previousState = model.state;
+  const event = {
+    type: 'transition',
+    action,
+    previousState,
+    nextState,
+    actor: actor.id,
+    meta: clone(meta),
+  };
+  return {
+    ...model,
+    state: nextState,
+    history: [...model.history, event],
+  };
+}
+
+
+function inspectHistory(model) {
+  const events = model.history.map((event, index) => ({ ...clone(event), index }));
+  const transitions = events.filter((event) => event.type === 'transition');
+  return {
+    featureKey: FEATURE.key,
+    auditLabel: 'promotion usage ledger',
+    eventCount: events.length,
+    latestState: model.state,
+    transitions,
+    rollbackHint: 'release reservation when order completion fails',
+  };
+}
+
+module.exports = { FEATURE, createModel, executeWorkflow, inspectHistory };
