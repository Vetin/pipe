--- /dev/null
+++ b/showcase/first-order-promotion-usage-caps/feature.s-002.test.js
@@ -0,0 +1,19 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow } = require('./feature');
+
+const model = createModel({ id: 'first-order-promotion-usage-caps-002' });
+const reviewed = executeWorkflow(
+  model,
+  'evaluate_first_order',
+  { id: 'reviewer-1' },
+  { reason: 'first-order promotion with usage caps' }
+);
+assert.equal(reviewed.state, 'eligible');
+assert.equal(reviewed.history.at(-1).previousState, 'cart');
+assert.equal(reviewed.history.at(-1).actor, 'reviewer-1');
+
+const finalized = executeWorkflow(reviewed, 'reserve_usage_cap', { id: 'approver-1' });
+assert.equal(finalized.state, 'reserved');
+assert.equal(finalized.history.length, 3);
diff --git a/showcase/first-order-promotion-usage-caps/feature.s-003.test.js b/showcase/first-order-promotion-usage-caps/feature.s-003.test.js
