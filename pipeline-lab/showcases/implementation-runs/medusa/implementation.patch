--- /dev/null
+++ b/showcase/first-order-promotion-usage-caps/feature.s-003.test.js
@@ -0,0 +1,14 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow, inspectHistory } = require('./feature');
+
+let model = createModel({ id: 'first-order-promotion-usage-caps-003' });
+model = executeWorkflow(model, 'evaluate_first_order', { id: 'actor-1' });
+model = executeWorkflow(model, 'reserve_usage_cap', { id: 'actor-2' }, { evidence: true });
+const audit = inspectHistory(model);
+
+assert.equal(audit.auditLabel, 'promotion usage ledger');
+assert.equal(audit.latestState, 'reserved');
+assert.equal(audit.transitions.length, 2);
+assert.match(audit.rollbackHint, /release/i);
