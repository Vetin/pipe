+'use strict';
+
+const assert = require('assert/strict');
+const { FEATURE, createModel } = require('./feature');
+
+const model = createModel({ id: 'first-order-promotion-usage-caps-001', entity: { title: 'First Order Promotion Usage Caps' } });
+assert.equal(FEATURE.key, 'first-order-promotion-usage-caps');
+assert.equal(model.state, 'cart');
+assert.equal(model.history[0].type, 'created');
+assert.equal(model.entity.title, 'First Order Promotion Usage Caps');
diff --git a/showcase/first-order-promotion-usage-caps/feature.s-002.test.js b/showcase/first-order-promotion-usage-caps/feature.s-002.test.js
