+'use strict';
+
+const assert = require('assert/strict');
+const { FEATURE, createModel } = require('./feature');
+
+const model = createModel({ id: "signed-survey-response-webhooks-001", entity: { title: "Signed Survey Response Webhooks" } });
+assert.equal(FEATURE.key, "signed-survey-response-webhooks");
+assert.equal(model.state, "configured");
+assert.equal(model.history[0].type, 'created');
+assert.equal(model.entity.title, "Signed Survey Response Webhooks");
diff --git a/showcase/signed-survey-response-webhooks/feature.s-002.test.js b/showcase/signed-survey-response-webhooks/feature.s-002.test.js
new file mode 100644
index 0000000..3ab8581
--- /dev/null
+++ b/showcase/signed-survey-response-webhooks/feature.s-002.test.js
@@ -0,0 +1,19 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow } = require('./feature');
+
+const model = createModel({ id: "signed-survey-response-webhooks-002" });
+const reviewed = executeWorkflow(
+  model,
+  "deliver_signed_payload",
+  { id: 'reviewer-1' },
+  { reason: "signed survey-response webhook delivery" }
+);
+assert.equal(reviewed.state, "delivered");
+assert.equal(reviewed.history.at(-1).previousState, "configured");
+assert.equal(reviewed.history.at(-1).actor, 'reviewer-1');
+
+const finalized = executeWorkflow(reviewed, "retry_failed_delivery", { id: 'approver-1' });
+assert.equal(finalized.state, "retry_scheduled");
+assert.equal(finalized.history.length, 3);
diff --git a/showcase/signed-survey-response-webhooks/feature.s-003.test.js b/showcase/signed-survey-response-webhooks/feature.s-003.test.js
