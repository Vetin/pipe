--- /dev/null
+++ b/showcase/signed-survey-response-webhooks/feature.s-003.test.js
@@ -0,0 +1,14 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow, inspectHistory } = require('./feature');
+
+let model = createModel({ id: "signed-survey-response-webhooks-003" });
+model = executeWorkflow(model, "deliver_signed_payload", { id: 'actor-1' });
+model = executeWorkflow(model, "retry_failed_delivery", { id: 'actor-2' }, { evidence: true });
+const audit = inspectHistory(model);
+
+assert.equal(audit.auditLabel, "delivery log");
+assert.equal(audit.latestState, "retry_scheduled");
+assert.equal(audit.transitions.length, 2);
+assert.match(audit.rollbackHint, /disable/i);
