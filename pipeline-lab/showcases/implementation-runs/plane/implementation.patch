@@ -0,0 +1,10 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { FEATURE, createModel } = require('./feature');
+
+const model = createModel({ id: "triage-automation-rules-001", entity: { title: "Triage Automation Rules" } });
+assert.equal(FEATURE.key, "triage-automation-rules");
+assert.equal(model.state, "untriaged");
+assert.equal(model.history[0].type, 'created');
+assert.equal(model.entity.title, "Triage Automation Rules");
diff --git a/showcase/triage-automation-rules/feature.s-002.test.js b/showcase/triage-automation-rules/feature.s-002.test.js
new file mode 100644
index 0000000..edab292
--- /dev/null
+++ b/showcase/triage-automation-rules/feature.s-002.test.js
@@ -0,0 +1,19 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow } = require('./feature');
+
+const model = createModel({ id: "triage-automation-rules-002" });
+const reviewed = executeWorkflow(
+  model,
+  "evaluate_rules",
+  { id: 'reviewer-1' },
+  { reason: "issue triage automation rules" }
+);
+assert.equal(reviewed.state, "matched");
+assert.equal(reviewed.history.at(-1).previousState, "untriaged");
+assert.equal(reviewed.history.at(-1).actor, 'reviewer-1');
+
+const finalized = executeWorkflow(reviewed, "apply_assignments", { id: 'approver-1' });
+assert.equal(finalized.state, "triaged");
+assert.equal(finalized.history.length, 3);
diff --git a/showcase/triage-automation-rules/feature.s-003.test.js b/showcase/triage-automation-rules/feature.s-003.test.js
new file mode 100644
index 0000000..d628e77
--- /dev/null
+++ b/showcase/triage-automation-rules/feature.s-003.test.js
@@ -0,0 +1,14 @@
+'use strict';
+
+const assert = require('assert/strict');
+const { createModel, executeWorkflow, inspectHistory } = require('./feature');
+
+let model = createModel({ id: "triage-automation-rules-003" });
+model = executeWorkflow(model, "evaluate_rules", { id: 'actor-1' });
+model = executeWorkflow(model, "apply_assignments", { id: 'actor-2' }, { evidence: true });
+const audit = inspectHistory(model);
+
+assert.equal(audit.auditLabel, "rule execution audit");
+assert.equal(audit.latestState, "triaged");
+assert.equal(audit.transitions.length, 2);
+assert.match(audit.rollbackHint, /remove/i);
