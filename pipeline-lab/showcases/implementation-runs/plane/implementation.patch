diff --git a/showcase/triage-automation-rules/feature.js b/showcase/triage-automation-rules/feature.js
new file mode 100644
index 0000000..e4e9e28
--- /dev/null
+++ b/showcase/triage-automation-rules/feature.js
@@ -0,0 +1,77 @@
+'use strict';
+
+const FEATURE = {
+  "key": "triage-automation-rules",
+  "name": "Triage Automation Rules",
+  "scenario": "issue triage automation rules",
+  "auditLabel": "rule execution audit"
+};
+
+function clone(value) {
+  return JSON.parse(JSON.stringify(value));
+}
+
+function createModel(input = {}) {
+  const entity = clone(input.entity || input);
+  return {
+    id: input.id || entity.id || `${FEATURE.key}-entity`,
+    featureKey: FEATURE.key,
+    scenario: FEATURE.scenario,
+    state: "untriaged",
+    entity,
+    history: [
+      {
+        type: 'created',
+        state: "untriaged",
+        actor: 'system',
+        note: FEATURE.name,
+      },
+    ],
+  };
+}
+
+
+const TRANSITIONS = {
+  "evaluate_rules": "matched",
+  "apply_assignments": "triaged",
+};
+
+function executeWorkflow(model, action, actor = {}, meta = {}) {
+  if (!TRANSITIONS[action]) {
+    throw new Error(`unsupported action: ${action}`);
+  }
+  if (!actor.id) {
+    throw new Error('actor id is required for auditable workflow execution');
+  }
+  const nextState = TRANSITIONS[action];
+  const previousState = model.state;
+  const event = {
+    type: 'transition',
+    action,
+    previousState,
+    nextState,
+    actor: actor.id,
+    meta: clone(meta),
+  };
+  return {
+    ...model,
+    state: nextState,
+    history: [...model.history, event],
+  };
+}
+
+
+function inspectHistory(model) {
+  const events = model.history.map((event, index) => ({ ...clone(event), index }));
+  const transitions = events.filter((event) => event.type === 'transition');
+  return {
+    featureKey: FEATURE.key,
+    auditLabel: "rule execution audit",
+    eventCount: events.length,
+    latestState: model.state,
+    transitions,
+    rollbackHint: "remove generated labels and restore previous assignee priority tuple",
+  };
+}
+
+module.exports = { FEATURE, createModel, executeWorkflow, inspectHistory };
diff --git a/showcase/triage-automation-rules/feature.s-001.test.js b/showcase/triage-automation-rules/feature.s-001.test.js
